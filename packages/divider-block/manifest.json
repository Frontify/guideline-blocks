{
    "appId": "cl5w9yz1l00010lw8dvragbie",
    "settingsSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
            "alignment": { "type": "string", "enum": ["Left", "Right", "Center"], "frontify-api-read": true },
            "style": { "type": "string", "enum": ["Dashed", "Solid", "Dotted"], "frontify-api-read": true },
            "isLine": { "type": "string", "enum": ["NoLine", "Solid"], "frontify-api-read": true },
            "color": {
                "frontify-api-read": true,
                "oneOf": [
                    { "type": "null" },
                    {
                        "type": "object",
                        "required": ["red", "green", "blue"],
                        "additionalProperties": false,
                        "properties": {
                            "red": { "type": "integer", "minimum": 0, "maximum": 255 },
                            "green": { "type": "integer", "minimum": 0, "maximum": 255 },
                            "blue": { "type": "integer", "minimum": 0, "maximum": 255 },
                            "alpha": { "type": "number", "minimum": 0, "maximum": 1 },
                            "name": { "type": "string" }
                        }
                    }
                ]
            },
            "isWidthCustom": { "type": "boolean", "frontify-api-read": true },
            "widthCustom": { "type": "string", "pattern": "^([1-9]?[0-9]|100)%$", "frontify-api-read": true },
            "widthSimple": { "type": "string", "enum": ["10%", "25%", "50%", "100%"], "frontify-api-read": true },
            "isHeightCustom": { "type": "boolean", "frontify-api-read": true },
            "heightCustom": { "type": "string", "pattern": "^[0-9]+px$", "frontify-api-read": true },
            "heightSimple": { "type": "string", "enum": ["Small", "Medium", "Large"], "frontify-api-read": true },
            "thickness": { "type": "string", "pattern": "^[0-9]+px$", "frontify-api-read": true }
        },
        "required": [
            "alignment",
            "style",
            "isLine",
            "isWidthCustom",
            "widthSimple",
            "isHeightCustom",
            "heightSimple",
            "thickness"
        ],
        "additionalProperties": false
    }
}
