{
    "appId": "cl5w86f8700010sw8yvfasdhx",
    "settingsSchema": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "additionalProperties": false,
        "properties": {
            "alignment": {
                "enum": ["left", "center", "right"],
                "frontify-api-read": true,
                "type": "string"
            },
            "appearance": {
                "enum": ["light", "strong"],
                "frontify-api-read": true,
                "type": "string"
            },
            "extendedRadiusBottomLeft": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "extendedRadiusBottomRight": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "extendedRadiusChoice": {
                "enum": ["None", "Small", "Medium", "Large"],
                "frontify-api-read": true,
                "type": "string"
            },
            "extendedRadiusTopLeft": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "extendedRadiusTopRight": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "hasCustomPadding": { "frontify-api-read": true, "type": "boolean" },
            "hasExtendedCustomRadius": { "frontify-api-read": true, "type": "boolean" },
            "iconSwitch": {
                "frontify-api-read": true,
                "frontify-translatable": true,
                "type": "boolean"
            },
            "iconType": {
                "enum": ["info", "none", "lightbulb", "megaphone"],
                "frontify-api-read": true,
                "frontify-translatable": true,
                "type": "string"
            },
            "paddingBottom": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "paddingChoice": {
                "enum": ["s", "m", "l"],
                "frontify-api-read": true,
                "type": "string"
            },
            "paddingLeft": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "paddingRight": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "paddingTop": { "frontify-api-read": true, "pattern": "^([0-9]+px)?$", "type": "string" },
            "textValue": {
                "frontify-api-read": true,
                "frontify-serializable": true,
                "frontify-translatable": true,
                "frontify-type": "fondueRte",
                "type": "string"
            },
            "type": {
                "enum": ["tip", "info", "warning", "note"],
                "frontify-api-read": true,
                "type": "string"
            },
            "width": {
                "enum": ["fullWidth", "hugContents"],
                "frontify-api-read": true,
                "type": "string"
            }
        },
        "required": [
            "type",
            "appearance",
            "iconSwitch",
            "iconType",
            "width",
            "alignment",
            "hasCustomPadding",
            "paddingChoice",
            "hasExtendedCustomRadius",
            "extendedRadiusChoice"
        ],
        "type": "object"
    }
}
