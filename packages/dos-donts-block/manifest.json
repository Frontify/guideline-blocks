{
    "appId": "cl5wa92p800010kw8fhpwvbjh",
    "settingsSchema": {
        "type": "object",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "$defs": {
            "color": {
                "type": ["null", "object"],
                "required": ["red", "green", "blue"],
                "additionalProperties": false,
                "properties": {
                    "red": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255,
                        "frontify-api-read": true,
                        "frontify-api-write": true
                    },
                    "green": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255,
                        "frontify-api-read": true,
                        "frontify-api-write": true
                    },
                    "blue": {
                        "type": "integer",
                        "minimum": 0,
                        "maximum": 255,
                        "frontify-api-read": true,
                        "frontify-api-write": true
                    },
                    "alpha": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1,
                        "frontify-api-read": true,
                        "frontify-api-write": true
                    },
                    "name": { "type": "string", "frontify-api-read": true, "frontify-api-write": true }
                }
            }
        },
        "required": [
            "mode",
            "style",
            "doIconChoice",
            "dontIconChoice",
            "hasStrikethrough",
            "columns",
            "keepSideBySide",
            "isCustomColumnGutter",
            "customColumnGutterValue",
            "columnGutterChoice",
            "isCustomRowGutter",
            "customRowGutterValue",
            "rowGutterChoice",
            "isCustomImageHeight",
            "customImageHeightValue",
            "imageHeightChoice",
            "imageDisplay",
            "hasCustomDoColor",
            "hasCustomDontColor",
            "hasBorder",
            "borderWidth",
            "borderStyle",
            "hasRadius",
            "radiusChoice",
            "hasBackground"
        ],
        "additionalProperties": false,
        "properties": {
            "mode": {
                "type": "string",
                "enum": ["text", "text_and_image"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "style": {
                "type": "string",
                "enum": ["icon", "underline", "text"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "hasCustomDoIcon": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "doIconChoice": {
                "type": "string",
                "enum": ["checkmark", "checkmarkCircle", "cross", "crossCircle"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "hasCustomDontIcon": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "dontIconChoice": {
                "type": "string",
                "enum": ["checkmark", "checkmarkCircle", "cross", "crossCircle"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "hasStrikethrough": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },

            "columns": {
                "type": "string",
                "enum": ["1", "2", "3", "4"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "keepSideBySide": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },

            "isCustomColumnGutter": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "customColumnGutterValue": {
                "type": "string",
                "pattern": "^[0-9]+px|normal$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "columnGutterChoice": {
                "type": "string",
                "enum": ["Auto", "Small", "Medium", "Large"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "isCustomRowGutter": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "customRowGutterValue": {
                "type": "string",
                "pattern": "^[0-9]+px|normal$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "rowGutterChoice": {
                "type": "string",
                "enum": ["Auto", "Small", "Medium", "Large"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "isCustomImageHeight": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "customImageHeightValue": {
                "type": "string",
                "pattern": "^[0-9]+px|auto$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "imageHeightChoice": {
                "type": "string",
                "enum": ["Auto", "Small", "Medium", "Large"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "imageDisplay": {
                "type": "string",
                "enum": ["fit", "fill"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "hasCustomDoColor": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "hasCustomDontColor": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "doColor": { "$ref": "#/$defs/color" },
            "dontColor": { "$ref": "#/$defs/color" },

            "hasBorder": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "borderWidth": {
                "type": "string",
                "pattern": "^[0-9]+px$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "borderStyle": {
                "type": "string",
                "enum": ["Solid", "Dashed", "Dotted"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "borderColor": { "$ref": "#/$defs/color" },

            "hasRadius": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "radiusValue": {
                "type": "string",
                "pattern": "^[0-9]+px$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "radiusChoice": {
                "type": "string",
                "enum": ["None", "Small", "Medium", "Large"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },

            "hasBackground": { "type": "boolean", "frontify-api-read": true, "frontify-api-write": true },
            "backgroundColor": { "$ref": "#/$defs/color" },

            "items": {
                "type": "array",
                "items": {
                    "type": "object",
                    "required": ["id", "type", "title", "body"],
                    "additionalProperties": false,
                    "properties": {
                        "id": {
                            "type": ["string", "integer"],
                            "pattern": "^(id-[0-9]+|c[0-9a-z]{24}|[0-9]+|[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})$",
                            "frontify-api-read": true,
                            "frontify-api-write": true,
                            "frontify-translatable": true
                        },
                        "type": {
                            "type": "string",
                            "enum": ["Do", "Dont"],
                            "frontify-api-read": true,
                            "frontify-api-write": true,
                            "frontify-translatable": true
                        },
                        "title": {
                            "type": "string",
                            "frontify-api-read": true,
                            "frontify-api-write": true,
                            "frontify-translatable": true,
                            "frontify-serializable": true,
                            "frontify-serialization-index": 1
                        },
                        "body": {
                            "type": "string",
                            "frontify-api-read": true,
                            "frontify-api-write": true,
                            "frontify-translatable": true,
                            "frontify-serializable": true,
                            "frontify-type": "fondueRte",
                            "frontify-serialization-index": 2
                        },
                        "alt": {
                            "type": "string",
                            "frontify-api-read": true,
                            "frontify-api-write": true,
                            "frontify-translatable": true
                        }
                    }
                }
            }
        }
    }
}
