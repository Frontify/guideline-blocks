{
    "appId": "cl5wahpvm00010kw8i71fyc6m",
    "settingsSchema": {
        "type": "object",
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "required": [],
        "additionalProperties": false,
        "properties": {
            "figmaPreviewId": {
                "type": "string",
                "enum": ["image", "live"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "hasLimitedOptions": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "isCustomHeight": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "heightValue": {
                "type": "string",
                "pattern": "^(auto|[0-9]+px)$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "heightChoice": {
                "type": "string",
                "enum": ["small", "medium", "large"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "allowFullScreen": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "allowZooming": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "showFigmaLink": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "hasBackground": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "backgroundColor": {
                "type": "object",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "hasBorder": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "borderStyle": {
                "type": "string",
                "enum": ["dotted", "dashed", "solid"],
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "borderWidth": {
                "type": "string",
                "pattern": "^[0-9]+px$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "borderColor": {
                "type": "object",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "hasRadius": {
                "type": "boolean",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "radiusValue": {
                "type": "string",
                "pattern": "^[0-9]+px$",
                "frontify-api-read": true,
                "frontify-api-write": true
            },
            "radiusChoice": {
                "type": "string",
                "frontify-api-read": true,
                "frontify-api-write": true
            }
        }
    }
}
