{
    "compilerOptions": {
        "esModuleInterop": true,
        "jsx": "react",
        "lib": ["dom", "dom.iterable", "esnext"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noUnusedLocals": true,
        "outDir": "dist",
        "resolveJsonModule": true,
        "noUncheckedSideEffectImports": false,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2020",
        "types": ["@testing-library/jest-dom"]
    },
    "exclude": ["node_modules", "dist"],
    "include": ["src/**/*"]
}
